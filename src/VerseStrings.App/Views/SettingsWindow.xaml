<Window x:Class="VerseStrings.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VerseStrings"
        Width="520" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1e1e23"
        Foreground="#e8e8ec"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e8e8ec" />
            <Setter Property="Margin" Value="0,6,0,2" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2a2a31" />
            <Setter Property="Foreground" Value="#e8e8ec" />
            <Setter Property="BorderBrush" Value="#3a3a44" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <!-- Why a full ComboBox ControlTemplate: the default WPF template applies
             SystemColors to the selection-display Border when the dropdown is open
             or the control is focused, which overrides our dark Background. The
             v0.1.9 ComboBoxItem fix only addressed the dropdown items; this fixes
             the header (closed-selection display) when the box is active. -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2a2a31" />
            <Setter Property="Foreground" Value="#e8e8ec" />
            <Setter Property="BorderBrush" Value="#3a3a44" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="22" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="MainBorder"
                                    Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1" />

                            <ContentPresenter Grid.Column="0"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />

                            <ToggleButton Grid.Column="1"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}">
                                            <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                  Fill="#e8e8ec"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#2a2a31"
                                        BorderBrush="#3a3a44"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#3d6dd0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#5a5a66" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Why a full ControlTemplate: the default ComboBoxItem template has
             internal triggers that override Background to SystemColors.HighlightBrush
             when IsHighlighted is true. Setting Background via a Style.Setter alone
             only colors the non-highlighted state — leaving the highlighted/selected
             item rendered as low-contrast near-white text on the system's light blue.
             A custom template lets us drive both states explicitly. -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2a2a31" />
            <Setter Property="Foreground" Value="#e8e8ec" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3d6dd0" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3a3a44" />
            <Setter Property="Foreground" Value="#e8e8ec" />
            <Setter Property="BorderBrush" Value="#4a4a55" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="MinWidth" Value="90" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e8e8ec" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0"
                   FontSize="18" FontWeight="SemiBold"
                   Text="VerseStrings Settings"
                   Margin="0,0,0,8" />

        <TextBlock Grid.Row="1" Text="Star Citizen LIVE folder" />
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="LiveFolderBox" Grid.Column="0" />
            <Button Grid.Column="1" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseClicked" />
        </Grid>
        <TextBlock Grid.Row="3"
                   FontSize="11" Foreground="#a0a0a8"
                   Text="The folder that contains Bin64\StarCitizen.exe" />

        <TextBlock Grid.Row="4" Text="Localization pack" Margin="0,14,0,2" />
        <ComboBox x:Name="PackBox" Grid.Row="5" />

        <StackPanel x:Name="IntervalPanel" Grid.Row="6" Orientation="Horizontal" Margin="0,14,0,0">
            <TextBlock Text="Check every" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBox x:Name="IntervalBox" Width="60" Text="15" />
            <TextBlock Text="minutes" Margin="8,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <CheckBox x:Name="AutostartBox" Grid.Row="7" Margin="0,14,0,0"
                  Content="Start VerseStrings when Windows starts" />

        <TextBlock Grid.Row="8" x:Name="StatusText" VerticalAlignment="Bottom"
                   FontSize="11" Foreground="#a0a0a8" Margin="0,14,0,0" />

        <StackPanel Grid.Row="9" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="CloseButton" Content="Close" Click="OnCloseClicked"
                    Margin="0,0,8,0" Visibility="Collapsed" />
            <Button x:Name="CancelButton" Content="Cancel" Click="OnCancelClicked" Margin="0,0,8,0" />
            <Button x:Name="SaveButton" Content="Save" Click="OnSaveClicked"
                    Background="#3d6dd0" Foreground="White" />
            <Button x:Name="SyncButton" Content="Sync now" Click="OnSyncClicked"
                    Background="#3d6dd0" Foreground="White" Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</Window>
