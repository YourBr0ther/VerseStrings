<Window x:Class="VerseStrings.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VerseStrings"
        Width="520" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1e1e23"
        Foreground="#e8e8ec"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e8e8ec" />
            <Setter Property="Margin" Value="0,6,0,2" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2a2a31" />
            <Setter Property="Foreground" Value="#e8e8ec" />
            <Setter Property="BorderBrush" Value="#3a3a44" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2a2a31" />
            <Setter Property="Foreground" Value="#e8e8ec" />
            <Setter Property="BorderBrush" Value="#3a3a44" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3a3a44" />
            <Setter Property="Foreground" Value="#e8e8ec" />
            <Setter Property="BorderBrush" Value="#4a4a55" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="MinWidth" Value="90" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e8e8ec" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0"
                   FontSize="18" FontWeight="SemiBold"
                   Text="VerseStrings Settings"
                   Margin="0,0,0,8" />

        <TextBlock Grid.Row="1" Text="Star Citizen LIVE folder" />
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="LiveFolderBox" Grid.Column="0" />
            <Button Grid.Column="1" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseClicked" />
        </Grid>
        <TextBlock Grid.Row="3"
                   FontSize="11" Foreground="#a0a0a8"
                   Text="The folder that contains Bin64\StarCitizen.exe" />

        <TextBlock Grid.Row="4" Text="Localization pack" Margin="0,14,0,2" />
        <ComboBox x:Name="PackBox" Grid.Row="5" />

        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,14,0,0">
            <TextBlock Text="Check every" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBox x:Name="IntervalBox" Width="60" Text="15" />
            <TextBlock Text="minutes" Margin="8,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <CheckBox x:Name="AutostartBox" Grid.Row="7" Margin="0,14,0,0"
                  Content="Start VerseStrings when Windows starts" />

        <TextBlock Grid.Row="8" x:Name="StatusText" VerticalAlignment="Bottom"
                   FontSize="11" Foreground="#a0a0a8" Margin="0,14,0,0" />

        <StackPanel Grid.Row="9" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Click="OnCancelClicked" Margin="0,0,8,0" />
            <Button Content="Save" Click="OnSaveClicked"
                    Background="#3d6dd0" Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
